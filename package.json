    "bcryptjs": "^2.4.3",
    "jose": "^5.2.3",
    "date-fns": "^3.3.1",
    "decimal.js": "^10.4.3",
    "@tanstack/react-query": "^5.24.1",
    "@tanstack/react-table": "^8.13.2",
    "recharts": "^2.12.1",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1",
    "lucide-react": "^0.344.0",
    "react-dropzone": "^14.2.3",
    "jspdf": "^2.5.1",
    "papaparse": "^5.4.1",
    "nodemailer": "^6.9.11"
